# Stackryze 配置
STACKRYZE_EMAIL=your_stackryze_email@example.com
STACKRYZE_PASSWORD=your_stackryze_password

# Cloudflare 配置
CLOUDFLARE_EMAIL=your_cloudflare_email@example.com
CLOUDFLARE_API_KEY=your_cloudflare_global_api_key
# 或者使用 API Token（推荐）
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# 通知配置（可选）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
NOTIFICATION_EMAIL=your_notification_email@example.com
NOTIFICATION_PASSWORD=your_notification_email_password